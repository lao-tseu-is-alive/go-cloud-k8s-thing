apiVersion: v1
kind: Secret
metadata:
  name: app-secrets-go-cloud-k8s-thing
  namespace: go-testing
type: Opaque
stringData:
  # NOTE: REPLACE THESE VALUES WITH YOUR ACTUAL SECRETS BEFORE DEPLOYMENT
  # DO NOT COMMIT ACTUAL SECRETS TO VERSION CONTROL!
  
  ADMIN_PASSWORD: "YOUR_ADMIN_PASSWORD"
  ADMIN_USER: "YOUR_ADMIN_USERNAME"
  ADMIN_EMAIL: "admin@example.com"
  ADMIN_ID: "12345"
  ADMIN_EXTERNAL_ID: "8"
  ALLOWED_HOSTS: "localhost,*,soi-app.example.com"
  
  # Database Configuration
  DB_DRIVER: "postgres"
  DB_HOST: "127.0.0.1"        # Change to your DB host
  DB_NAME: "your_db_name"
  DB_PASSWORD: "YOUR_DB_PASSWORD"
  DB_PORT: "5432"
  DB_SSL_MODE: "prefer"
  DB_USER: "your_db_user"
  
  # JWT Configuration
  JWT_DURATION_MINUTES: "240"
  JWT_SECRET: "YOUR_STRONG_JWT_SECRET_KEY_HERE"
  JWT_ISSUER_ID: "00000000-0000-0000-0000-000000000000"
  JWT_CONTEXT_KEY: "gojwtdata"
  JWT_COOKIE_NAME: "goJWT_token"
  JWT_AUTH_URL: "/gologin"
  JWT_STATUS_URL: "/status"
